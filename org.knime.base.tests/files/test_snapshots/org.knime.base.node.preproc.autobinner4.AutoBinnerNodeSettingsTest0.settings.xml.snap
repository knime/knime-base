<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <config key="selectedColumns">
        <entry key="mode" type="xstring" value="MANUAL"/>
        <config key="patternFilter">
            <entry key="pattern" type="xstring" value=""/>
            <entry key="isCaseSensitive" type="xboolean" value="false"/>
            <entry key="isInverted" type="xboolean" value="false"/>
        </config>
        <config key="manualFilter">
            <config key="manuallySelected">
                <entry key="array-size" type="xint" value="5"/>
                <entry key="0" type="xstring" value="Universe_0_0"/>
                <entry key="1" type="xstring" value="Universe_0_1"/>
                <entry key="2" type="xstring" value="Universe_1_0"/>
                <entry key="3" type="xstring" value="Universe_1_1"/>
                <entry key="4" type="xstring" value="newvalue"/>
            </config>
            <config key="manuallyDeselected">
                <entry key="array-size" type="xint" value="0"/>
            </config>
            <entry key="includeUnknownColumns" type="xboolean" value="false"/>
        </config>
        <config key="typeFilter">
            <config key="selectedTypes">
                <entry key="array-size" type="xint" value="0"/>
            </config>
        </config>
    </config>
    <entry key="binningType" type="xstring" value="EQUAL_WIDTH"/>
    <entry key="numberOfBins" type="xint" value="20"/>
    <config key="customCutoffs">
        <config key="0">
            <entry key="cutoff" type="xdouble" value="0.0"/>
            <entry key="matchType" type="xstring" value="TO_LOWER_BIN"/>
        </config>
    </config>
    <config key="customQuantiles">
        <config key="0">
            <entry key="quantile" type="xdouble" value="0.0"/>
            <entry key="matchType" type="xstring" value="TO_LOWER_BIN"/>
        </config>
    </config>
    <entry key="enforceIntegerCutoffs" type="xboolean" value="false"/>
    <entry key="fixLowerBound" type="xboolean" value="false"/>
    <entry key="fixedLowerBound" type="xdouble" value="0.0"/>
    <entry key="fixUpperBound" type="xboolean" value="false"/>
    <entry key="fixedUpperBound" type="xdouble" value="0.0"/>
    <entry key="binNames" type="xstring" value="NUMBERED"/>
    <entry key="prefix" type="xstring" value="Bin "/>
    <entry key="lowerOutlierValue" type="xstring" value="Lower outlier"/>
    <entry key="upperOutlierValue" type="xstring" value="Upper outlier"/>
    <entry key="numberFormat" type="xstring" value="COLUMN_FORMAT"/>
    <config key="numberFormatSettings">
        <entry key="numberFormat" type="xstring" value="STANDARD_STRING"/>
        <entry key="precision" type="xint" value="3"/>
        <entry key="precisionMode" type="xstring" value="DECIMAL_PLACES"/>
        <entry key="roundingMode" type="xstring" value="UP"/>
    </config>
    <entry key="replaceOrAppend" type="xstring" value="REPLACE"/>
    <entry key="suffix" type="xstring" value=" (Binned)"/>
</config>
