<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <config key="referenceStructureColumns"/>
    <entry key="inputTableIsTemplate" type="xboolean" value="false"/>
    <entry key="columnNameMatchingBehavior" type="xstring" value="CASE_SENSITIVE"/>
    <entry key="missingColumnHandling" type="xstring" value="NONE"/>
    <entry key="additionalColumnsHandling" type="xstring" value="REJECT"/>
    <entry key="dataTypeHandling" type="xstring" value="FAIL"/>
    <entry key="validationFailureBehavior" type="xstring" value="FAIL_NODE"/>
</config>
