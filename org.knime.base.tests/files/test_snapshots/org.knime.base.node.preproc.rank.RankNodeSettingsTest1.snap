                  "text" : "String"
                },
                "compatibleTypes" : [ "org.knime.core.data.StringValue", "org.knime.core.data.DataValue", "org.knime.core.data.NominalValue" ]
              } ],
              "format" : "dropDown",
              "showNoneColumn" : false,
              "showRowKeys" : true,
              "showSearch" : true,
