{
  "data" : {
    "model" : {
      "missingOperation" : "IGNORE"
    }
  },
  "schema" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "column" : {
            "type" : "string",
            "title" : "Column name",
            "description" : "Name of the column for the values.\n",
            "default" : ""
          },
          "missingOperation" : {
            "oneOf" : [ {
              "const" : "IGNORE",
              "title" : "Ignore"
            }, {
              "const" : "FAIL",
              "title" : "Fail"
            } ],
            "title" : "Skip missing values",
            "description" : "<ul>\n    <li><strong>Ignore</strong>: rows with a missing value in the selected column will be skipped</li>\n    <li><strong>Fail</strong>: the node execution will fail if a row contains a missing value in the     selected column.</li>\n</ul>\n",
            "default" : "IGNORE"
          }
        }
      }
    }
  },
  "ui_schema" : {
    "elements" : [ {
      "type" : "Control",
      "scope" : "#/properties/model/properties/column",
      "options" : {
        "possibleValues" : [ {
          "id" : "Column 1",
          "text" : "Column 1",
          "type" : {
            "id" : "org.knime.core.data.StringValue",
            "text" : "String"
          },
          "compatibleTypes" : [ "org.knime.core.data.StringValue", "org.knime.core.data.DataValue", "org.knime.core.data.NominalValue" ]
        }, {
          "id" : "Column 2",
          "text" : "Column 2",
          "type" : {
            "id" : "org.knime.core.data.DoubleValue",
            "text" : "Number (double)"
          },
          "compatibleTypes" : [ "org.knime.core.data.DoubleValue", "org.knime.core.data.DataValue", "org.knime.core.data.ComplexNumberValue", "org.knime.core.data.FuzzyNumberValue", "org.knime.core.data.FuzzyIntervalValue", "org.knime.core.data.BoundedValue" ]
        } ],
        "format" : "dropDown",
        "showNoneColumn" : false,
        "showRowKeys" : false,
        "showSearch" : true,
        "showMode" : true
      }
    }, {
      "type" : "Control",
      "scope" : "#/properties/model/properties/missingOperation",
      "options" : {
        "format" : "valueSwitch"
      }
    } ]
  },
  "persist" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "column" : {
            "configKey" : "column"
          },
          "missingOperation" : {
            "configPaths" : [ [ "skip_missing" ] ]
          }
        }
      }
    }
  }
}