<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <config key="settings">
        <entry key="has_row_id" type="xboolean" value="false"/>
        <entry key="prepend_table_index_to_row_id" type="xboolean" value="false"/>
    </config>
    <entry key="column_filter_mode" type="xstring" value="UNION"/>
    <config key="configId_Internals">
        <config key="table_manipulator"/>
    </config>
    <config key="transformationParameters">
        <config key="specs">
            <entry key="is_null" type="xboolean" value="true"/>
        </config>
        <entry key="enforceTypes" type="xboolean" value="true"/>
        <config key="columnTransformation">
            <config key="0">
                <entry key="columnName" type="xstring" isnull="true" value=""/>
                <entry key="originalTypeLabel" type="xstring" value="Default columntype"/>
                <entry key="includeInOutput" type="xboolean" value="true"/>
                <entry key="columnRename" type="xstring" isnull="true" value=""/>
                <entry key="unknownsColumnDataType" type="xstring" value="&lt;default-columntype&gt;"/>
            </config>
        </config>
    </config>
</config>
