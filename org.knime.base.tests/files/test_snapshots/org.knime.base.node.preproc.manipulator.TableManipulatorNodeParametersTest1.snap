  "schema" : {
    "type" : "object",
    "properties" : {
      "model" : {
        "type" : "object",
        "properties" : {
          "parameters" : {
            "type" : "object",
            "properties" : {
              "columnFilterMode" : {
                "oneOf" : [ {
                  "const" : "UNION",
                  "title" : "Union"
                }, {
                  "const" : "INTERSECTION",
                  "title" : "Intersection"
                } ],
                "title" : "Take columns from",
                "description" : "Only relevant when several input tables are available. Specifies which set of columns is considered for the output table. <br /><b>Note:</b><br/>This setting has special implications if you are changing the input table without reconfiguring the node. If <i>Intersection</i> is selected, any column that moves into the intersection during execution will be considered to be new, even if it was previously part of the union of columns.\n<ul>\n<li><b>Union</b>: Any column that is part of any input table is considered. If an input table is missing a column, it is filled up with missing values.</li>\n<li><b>Intersection</b>: Only columns that appear in all input tables are considered for the output table.</li>\n</ul>",
                "default" : "UNION"
              },
              "settings" : {
                "type" : "object",
                "properties" : {
                  "initialPrependTableIndexToRowID" : {
                    "type" : "boolean",
                    "default" : false
                  },
                  "prependTableIndexToRowID" : {
                    "type" : "boolean",
                    "title" : "Prepend table index to RowID",
                    "description" : "Only enabled if the existing RowIDs are used. If checked, a prefix is prepended to the RowIDs that indicates which table the row came from. The format of the prefix is \"Table_0_\", \"Table_1_\", and so on.",
                    "default" : false
                  },
                  "useExistingRowID" : {
                    "type" : "boolean",
                    "title" : "Use existing RowID",
                    "description" : "Check this box if the RowIDs from the input tables should be used for the output tables.If unchecked, a new RowID is generated. The generated RowID follows the schema \"Row0\", \"Row1\" and so on.",
                    "default" : false
                  }
                },
                "default" : {
                  "useExistingRowID" : false,
                  "prependTableIndexToRowID" : false,
                  "initialPrependTableIndexToRowID" : false
                }
              }
            },
            "default" : {
              "settings" : {
                "useExistingRowID" : false,
                "prependTableIndexToRowID" : false,
                "initialPrependTableIndexToRowID" : false
              },
              "columnFilterMode" : "UNION"
            }
          },
          "transformationParameters" : {
            "type" : "object",
            "properties" : {
              "columnTransformation" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "properties" : {
                    "columnName" : {
                      "type" : "string"
                    },
                    "columnRename" : {
                      "type" : "string",
                      "title" : "Column name"
                    },
                    "includeInOutput" : {
                      "type" : "boolean",
                      "title" : "Include in output",
                      "default" : false
                    },
                    "originalProductionPath" : {
                      "type" : "string"
                    },
                    "originalTypeLabel" : {
                      "type" : "string"
                    },
                    "productionPath" : {
                      "type" : "string",
                      "title" : "Column type"
                    }
                  }
                },
                "title" : "Transformations",
                "description" : "This option allows modifying the structure of the output table. It supports reordering, filtering and\nrenaming columns. It is also possible to change the type of the columns.\nWhether and where to add unknown columns during execution is specified via the special entry\n<i>Any unknown column</i>.\n<br />\n<b>Note:</b><br />\nThe transformation matching during execution is based on name. That means if there was a column\n[A, Integer] during configuration in the dialog and this column becomes [A, String] during execution, then\nthe stored transformation is applied to it. For filtering, ordering and renaming, this is straight forward.\nFor type mapping the following is done: If there is an alternative converter to the specified KNIME type,\nthen this converter is used, otherwise we default to the default KNIME type for the new type. In our example\nwe might have specified that [A, Integer] should be mapped to Long. For the changed column [A, String] there\nis no converter to Long, so we default back to String and A becomes a String column in the output table.\n",
                "default" : [ {
                  "columnName" : null,
                  "originalProductionPath" : "<default-columntype>",
                  "originalTypeLabel" : "Default columntype",
                  "includeInOutput" : true,
                  "columnRename" : null,
                  "productionPath" : "<default-columntype>"
                } ]
              },
              "dirtyTracker" : {
                "type" : "object"
              },
              "enforceTypes" : {
                "type" : "boolean",
                "title" : "Enforce types",
                "description" : "Controls how columns whose type changes are dealt with.\nIf selected, the mapping to the KNIME type you configured is attempted.\nThe node will fail if that is not possible.\nIf unselected, the KNIME type corresponding to the new type is used.\n",
                "default" : true
              },
              "initialColumnTransformation" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "properties" : {
                    "columnName" : {
                      "type" : "string"
                    },
                    "columnRename" : {
                      "type" : "string"
                    },
                    "includeInOutput" : {
                      "type" : "boolean",
                      "default" : false
                    },
                    "originalProductionPath" : {
                      "type" : "string"
                    },
                    "originalTypeLabel" : {
                      "type" : "string"
                    },
                    "productionPath" : {
                      "type" : "string"
                    }
                  }
                },
                "default" : [ ]
              },
              "specs" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "properties" : {
                    "sourceIdentifier" : {
                      "type" : "string"
                    },
                    "spec" : {
                      "type" : "array",
                      "items" : {
                        "type" : "object",
                        "properties" : {
                          "hasType" : {
                            "type" : "boolean",
                            "default" : false
                          },
                          "name" : {
                            "type" : "string"
                          },
                          "type" : {
                            "type" : "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "default" : {
              "enforceTypes" : true,
              "columnTransformation" : [ {
                "columnName" : null,
                "originalProductionPath" : "<default-columntype>",
                "originalTypeLabel" : "Default columntype",
                "includeInOutput" : true,
                "columnRename" : null,
                "productionPath" : "<default-columntype>"
              } ],
              "initialColumnTransformation" : [ ]
            }
          }
        }
      }
    }
  },
