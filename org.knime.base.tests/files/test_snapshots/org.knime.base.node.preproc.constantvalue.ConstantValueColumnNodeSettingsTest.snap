                  "description" : "The name of the column to replace."
                },
                "customOrMissingValue" : {
                  "oneOf" : [ {
                    "const" : "MISSING",
                    "title" : "Missing"
                  }, {
                    "const" : "CUSTOM",
                    "title" : "Custom"
                  } ],
                  "title" : "Fill value",
                  "description" : "Whether to use a custom value for the new column, or fill it with missing cells.\n",
