                  "description" : "The type of the new column.",
                  "default" : "STRING"
                },
                "value" : {
                  "type" : "string",
                  "title" : "Custom value",
                  "description" : "The value to be used when filling the output column.",
                  "default" : ""
                }
              }
            },
